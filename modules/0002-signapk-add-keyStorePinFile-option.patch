From af5e89d97f20b7a1d2a207f3c14c5582413eba0e Mon Sep 17 00:00:00 2001
From: cyclopentane <cyclopentane@aidoskyneen.eu>
Date: Fri, 27 Feb 2026 21:31:38 +0100
Subject: [PATCH 2/3] signapk: add keyStorePinFile option

---
 .../signapk/src/com/android/signapk/SignApk.java  | 15 ++++++++++++++-
 1 file changed, 14 insertions(+), 1 deletion(-)

diff --git a/tools/signapk/src/com/android/signapk/SignApk.java b/tools/signapk/src/com/android/signapk/SignApk.java
index 654e19675d..2c203eb4ff 100644
--- a/tools/signapk/src/com/android/signapk/SignApk.java
+++ b/tools/signapk/src/com/android/signapk/SignApk.java
@@ -62,6 +62,8 @@ import java.io.RandomAccessFile;
 import java.lang.reflect.Constructor;
 import java.nio.ByteBuffer;
 import java.nio.ByteOrder;
+import java.nio.file.Files;
+import java.nio.file.Paths;
 import java.nio.charset.StandardCharsets;
 import java.security.GeneralSecurityException;
 import java.security.NoSuchAlgorithmException;
@@ -1062,6 +1064,7 @@ class SignApk {
                            "[-providerArg <configureArg>] " +
                            "[-loadPrivateKeysFromKeyStore <keyStoreName>]" +
                            "[-keyStorePin <pin>]" +
+			   "[-keyStorePinFile <pin-file>]" +
                            "[--min-sdk-version <n>] " +
                            "[--disable-v2] " +
                            "[--enable-v4] " +
@@ -1124,7 +1127,17 @@ class SignApk {
                 }
                 keyStorePin = args[++argstart];
                 ++argstart;
-            } else if ("-a".equals(args[argstart])) {
+            } else if ("-keyStorePinFile".equals(args[argstart])) {
+		if (argstart + 1 >= args.length) {
+		    usage();
+		}
+		try {
+		    keyStorePin = new String(Files.readAllBytes(Paths.get(args[++argstart])));
+		} catch (IOException e) {
+		    throw new IllegalArgumentException("could not read PIN file");
+		}
+		++argstart;
+	    } else if ("-a".equals(args[argstart])) {
                 alignment = Integer.parseInt(args[++argstart]);
                 ++argstart;
             } else if ("--align-file-size".equals(args[argstart])) {
-- 
2.52.0

